{
  "compilerOptions": {
    "module": "ES2022",
    "target": "ES2022",
    "esModuleInterop": true,
    "moduleResolution": "Bundler",
    "outDir": "./lib",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
    },
    "rootDir": ".",
    "declaration": false,
    "noImplicitAny": true,
    "strict": true
  },
  "include": [
    "src/**/*",
    "web.config.ts",
    "test/**/*.ts"
  ],
  "exclude": [
    "node_modules",
  ]
}
